function PrestineManager:SetupConfig(PrestineLib)
	if not self:IsExcluded("Config Management") then
		PrestineLib:AddSection({ Tab = "Config", MainTitle = "Config Management" })
	end

	local selectedConfig = "Default"
	local configNameInput = "Default"
	local autoloadFile = ConfigFolder .. "/" .. game.PlaceId .. "_autoload.txt"

	local overwriteBtnSub, loadBtnSub, delBtnSub, autoBtnSub
	local saveBtnSub

	local configDropdown
	if not self:IsExcluded("Select Config") then
		configDropdown = PrestineLib:AddDropdown({
			Tab = "Config",
			MainTitle = "Select Config",
			ChoiceList = getConfigs(),
			DefaultChoice = "Default",
			Multiple = false,
			Callback = function(v)
				selectedConfig = typeof(v) == "table" and v[1] or v
				local txt = tostring(selectedConfig)
				if overwriteBtnSub then overwriteBtnSub.Text = "Target: " .. txt end
				if loadBtnSub then loadBtnSub.Text = "Target: " .. txt end
				if delBtnSub then delBtnSub.Text = "Target: " .. txt end
				if autoBtnSub then autoBtnSub.Text = "Target: " .. txt end
			end
		})
	end

	if not self:IsExcluded("Config Name") then
		PrestineLib:AddInput({
			Tab = "Config",
			MainTitle = "Config Name",
			PlaceHolder = "Enter config name...",
			Callback = function(v)
				configNameInput = v
				if saveBtnSub then saveBtnSub.Text = "Save As: " .. tostring(v) end
			end
		})
	end

	local function refreshDropdown()
		pcall(function()
			if configDropdown and configDropdown.UpdateDropdown then
				configDropdown:UpdateDropdown(getConfigs())
			end
		end)
	end

	if not self:IsExcluded("Create / Save Config") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Create / Save Config",
			SubTitle = "Save typed config name",
			Callback = function()
				if configNameInput and configNameInput ~= "" then
					saveConfig(configNameInput)
					refreshDropdown()
					PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Saved " .. configNameInput, Duration = 3 })
				end
			end
		})
		saveBtnSub = getSubtitleLabel(btn)
		if saveBtnSub then saveBtnSub.Text = "Save As: " .. tostring(configNameInput) end
	end

	if not self:IsExcluded("Overwrite Selected Config") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Overwrite Selected Config",
			SubTitle = "Target: " .. tostring(selectedConfig),
			Callback = function()
				if selectedConfig and selectedConfig ~= "" then
					saveConfig(selectedConfig)
					PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Overwrote " .. selectedConfig, Duration = 3 })
				end
			end
		})
		overwriteBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Load Selected Config") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Load Selected Config",
			SubTitle = "Target: " .. tostring(selectedConfig),
			Callback = function()
				if selectedConfig and selectedConfig ~= "" then
					if loadConfig(selectedConfig) then
						PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Loaded " .. selectedConfig, Duration = 3 })
					else
						PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Failed to load", Duration = 3 })
					end
				end
			end
		})
		loadBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Delete Selected Config") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Delete Selected Config",
			SubTitle = "Target: " .. tostring(selectedConfig),
			Callback = function()
				if selectedConfig and selectedConfig ~= "" then
					deleteConfig(selectedConfig)
					refreshDropdown()
					PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Deleted " .. selectedConfig, Duration = 3 })
				end
			end
		})
		delBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Set As Autoload") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Set As Autoload",
			SubTitle = "Target: " .. tostring(selectedConfig),
			Callback = function()
				if selectedConfig and selectedConfig ~= "" then
					initFolders()
					pcall(function() writefile(autoloadFile, selectedConfig) end)
					PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Autoload set to " .. selectedConfig, Duration = 3 })
				end
			end
		})
		autoBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Auto Save Component Toggles") then
		PrestineLib:AddSaveToggle({
			Tab = "Config",
			MainName = "Auto Save Component Toggles",
			DefaultState = true
		})
	end

	task.spawn(function()
		pcall(function()
			if isfile(autoloadFile) then
				local autoName = readfile(autoloadFile)
				if autoName and autoName ~= "" then
					if loadConfig(autoName) then
						PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Auto-loaded " .. autoName, Duration = 3 })
					end
				end
			end
		end)
	end)
end

function PrestineManager:Init(PrestineLib, options)
	self._initOptions = options or {}
	local tabsToInit = self._initOptions.Tabs or { "Home", "Player", "Performance", "Utility", "Settings", "Config" }
	
	PrestineLib:Set("PrestineHub", tostring(game.PlaceId))

	-- Default Icons dictionary for Automatic Tab Creation
	local defaultTabIcons = {
		["Home"] = "Home",
		["Player"] = "User",
		["Performance"] = "Gauge",
		["Utility"] = "Hammer",
		["Settings"] = "Settings",
		["Config"] = "Info"
	}
	
	-- Automatically construct the Tabs table based on what you asked to initialize
	local tabsToCreate = {}
	for _, tabName in ipairs(tabsToInit) do
		table.insert(tabsToCreate, {
			Name = tabName,
			Icon = defaultTabIcons[tabName] or "Info" -- Default to Info if no icon mapping exists
		})
	end
	
	-- Create the tabs inside the UI
	PrestineLib:CreateTab(tabsToCreate)

	local Main = getgenv()._PrestineMain
	local function hasTab(name)
		return Main and Main:FindFirstChild(name .. "Contents") ~= nil
	end

	if table.find(tabsToInit, "Home") and hasTab("Home") then self:SetupHome(PrestineLib) end
	if table.find(tabsToInit, "Player") and hasTab("Player") then self:SetupPlayer(PrestineLib) end
	if table.find(tabsToInit, "Performance") and hasTab("Performance") then self:SetupPerformance(PrestineLib) end
	if table.find(tabsToInit, "Utility") and hasTab("Utility") then self:SetupUtility(PrestineLib) end
	if table.find(tabsToInit, "Settings") and hasTab("Settings") then self:SetupSettings(PrestineLib) end
	if table.find(tabsToInit, "Config") and hasTab("Config") then self:SetupConfig(PrestineLib) end

	if self._uiConn then self._uiConn:Disconnect() end
	self._uiConn = RunService.Heartbeat:Connect(function()
		local char = player.Character
		if not char then return end

		local hum = char:FindFirstChildOfClass("Humanoid")
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hum then return end

		local statusText =
			"Task: " .. tostring(self.State.CurrentTask) ..
			"\nQueue: " .. #self._queue ..
			"\nMethod: " .. self.Config.TravelMethod ..
			"\nTweenSpeed: " .. self.Config.TweenSpeed ..
			"\nTeleportDelay: " .. self.Config.TeleportDelay ..
			"\nWalkSpeed: " .. hum.WalkSpeed ..
			"\nJump: " .. (hum.UseJumpPower and hum.JumpPower or hum.JumpHeight) ..
			"\nHealth: " .. string.format("%.0f/%.0f", hum.Health, hum.MaxHealth)

		if hrp then
			statusText ..= "\nState: " .. hum:GetState().Name .. "\nRoot Anchored: " .. tostring(hrp.Anchored)
		end

		if self._statusParagraph then
			self._statusParagraph:SetContent(statusText)
		end
	end)

	task.spawn(function()
		while true do
			task.wait(1)
			if self._serverStatusParagraph then
				self._serverStatusParagraph:SetContent(getServerInfoText())
			end
		end
	end)

	task.spawn(function()
		while true do
			task.wait(0.5)
			if self._perfParagraph then
				self._perfParagraph:SetContent(getPerformanceText(self))
			end
		end
	end)

	if self._fpsConn then self._fpsConn:Disconnect() end
	self._fpsConn = RunService.RenderStepped:Connect(function(dt)
		PrestineManager._fps = math.floor(1 / dt)
	end)
end

return PrestineManager
