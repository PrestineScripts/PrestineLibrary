local isfolder = isfolder or function() return false end
local makefolder = makefolder or function() end
local isfile = isfile or function() return false end
local readfile = readfile or function() return "" end
local writefile = writefile or function() end
local listfiles = listfiles or function() return {} end
local delfile = delfile or function() end

local ConfigFolder = "PrestineConfigs"
local ConfigSubFolder = ConfigFolder .. "/" .. game.PlaceId

local function initFolders()
	pcall(function()
		if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
		if not isfolder(ConfigSubFolder) then makefolder(ConfigSubFolder) end
	end)
end

local function getConfigs()
	initFolders()
	local list = {}
	pcall(function()
		for _, file in ipairs(listfiles(ConfigSubFolder)) do
			local name = file:match("([^/\\]+)%.json$")
			if name then table.insert(list, name) end
		end
	end)
	if #list == 0 then table.insert(list, "Default") end
	return list
end

local function saveConfig(name)
	initFolders()
	pcall(function()
		local data = HttpService:JSONEncode(PrestineManager.Config)
		writefile(ConfigSubFolder .. "/" .. name .. ".json", data)
	end)
end

local function loadConfig(name)
	initFolders()
	local success = false
	pcall(function()
		local path = ConfigSubFolder .. "/" .. name .. ".json"
		if isfile(path) then
			local decoded = HttpService:JSONDecode(readfile(path))
			if type(decoded) == "table" then
				for k, v in pairs(decoded) do
					PrestineManager.Config[k] = v
				end
				success = true
			end
		end
	end)
	return success
end

local function deleteConfig(name)
	pcall(function()
		local path = ConfigSubFolder .. "/" .. name .. ".json"
		if isfile(path) then delfile(path) end
	end)
end

