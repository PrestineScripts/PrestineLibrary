function PrestineManager:SetupConfig(PrestineLib)
	if not PrestineLib.gameFolderPath then
		PrestineLib:AddParagraph({
			Tab = "Config",
			MainTitle = "Config Unavailable",
			paragraphSize = 80,
			MainContent = "Call PrestineLib:Set(hubName, gameName) before Init to enable config saving and loading."
		})
		return
	end

	_G.PrestineManagerConfig = self.Config

	local localPath = PrestineLib.gameFolderPath
	local globalPath = PrestineLib.mainFolder and (PrestineLib.mainFolder .. "/_global") or nil

	if globalPath then
		pcall(function()
			if not isfolder(globalPath) then makefolder(globalPath) end
		end)
	end

	local configScope = "Local"
	local selectedConfig = "Default"
	local configNameInput = "Default"

	local function getCurrentPath()
		if configScope == "Global" then return globalPath end
		return localPath
	end

	local function getProfilesForScope()
		local path = getCurrentPath()
		local list = {}
		if path then
			pcall(function()
				for _, file in ipairs(listfiles(path)) do
					local name = file:match("([^/\\]+)%.json$")
					if name and not name:match("^_") then
						table.insert(list, name)
					end
				end
			end)
		end
		if #list == 0 then table.insert(list, "Default") end
		return list
	end

	local function saveToScope(name)
		local path = getCurrentPath()
		if not path then return false end
		local data = {}
		for k, v in pairs(PrestineLib.data or {}) do data[k] = v end
		if type(_G.PrestineManagerConfig) == "table" then
			data["_ManagerConfig"] = _G.PrestineManagerConfig
		end
		local ok = false
		pcall(function()
			if not isfolder(path) then makefolder(path) end
			local filePath = path .. "/" .. name .. ".json"
			writefile(filePath, game:GetService("HttpService"):JSONEncode(data))
			ok = true
		end)
		return ok
	end

	local function loadFromScope(name)
		local path = getCurrentPath()
		if not path then return false end
		local filePath = path .. "/" .. name .. ".json"
		local ok = false
		pcall(function()
			if isfile(filePath) then
				local decoded = game:GetService("HttpService"):JSONDecode(readfile(filePath))
				if type(decoded) == "table" then
					PrestineLib.data = decoded
					ok = true
				end
			end
		end)
		if ok then
			PrestineLib._IsLoading = true
			if PrestineLib.data["_ManagerConfig"] and type(_G.PrestineManagerConfig) == "table" then
				for k, v in pairs(PrestineLib.data["_ManagerConfig"]) do
					_G.PrestineManagerConfig[k] = v
					self.Config[k] = v
				end
			end
			for cname, comp in pairs(PrestineLib.Registry) do
				local savedVal = PrestineLib.data[cname]
				if savedVal ~= nil then
					pcall(function() comp:Set(savedVal) end)
				end
			end
			PrestineLib._IsLoading = false
		end
		return ok
	end

	local function deleteFromScope(name)
		local path = getCurrentPath()
		if not path then return end
		pcall(function()
			local filePath = path .. "/" .. name .. ".json"
			if isfile(filePath) then delfile(filePath) end
		end)
	end

	local configDropdown
	local overwriteBtnSub, loadBtnSub, delBtnSub, autoBtnSub, saveBtnSub

	local function refreshDropdown()
		pcall(function()
			if configDropdown and configDropdown.UpdateDropdown then
				task.wait(0.1)
				configDropdown:UpdateDropdown(getProfilesForScope())
			end
		end)
	end

	local function updateAllTargetLabels()
		local txt = tostring(selectedConfig)
		if overwriteBtnSub then overwriteBtnSub.Text = "Target: " .. txt end
		if loadBtnSub then loadBtnSub.Text = "Target: " .. txt end
		if delBtnSub then delBtnSub.Text = "Target: " .. txt end
		if autoBtnSub then autoBtnSub.Text = "Target: " .. txt end
	end

	if not self:IsExcluded("Config Scope") then
		PrestineLib:AddSection({ Tab = "Config", MainTitle = "Config Scope" })
	end

	if not self:IsExcluded("Scope") then
		PrestineLib:AddDropdown({
			Tab = "Config",
			MainTitle = "Scope",
			Description = "Global = shared across all games.  Local = this game only.",
			ChoiceList = { "Local", "Global" },
			DefaultChoice = "Local",
			Multiple = false,
			Callback = function(v)
				local val = typeof(v) == "table" and v[1] or v
				configScope = tostring(val or "Local")
				selectedConfig = "Default"
				updateAllTargetLabels()
				refreshDropdown()
			end
		})
	end

	if not self:IsExcluded("Config Selection") then
		PrestineLib:AddSection({ Tab = "Config", MainTitle = "Config Selection" })
	end

	if not self:IsExcluded("Select Config") then
		configDropdown = PrestineLib:AddDropdown({
			Tab = "Config",
			MainTitle = "Select Config",
			Description = "Pick a config from the current scope.",
			ChoiceList = getProfilesForScope(),
			DefaultChoice = "Default",
			Multiple = false,
			Callback = function(v)
				local val = typeof(v) == "table" and v[1] or v
				selectedConfig = tostring(val or "Default")
				updateAllTargetLabels()
			end
		})
	end

	if not self:IsExcluded("Config Name") then
		PrestineLib:AddInput({
			Tab = "Config",
			MainTitle = "Config Name",
			PlaceHolder = "Enter config name...",
			Callback = function(v)
				if v and v ~= "" then
					configNameInput = v
					if saveBtnSub then saveBtnSub.Text = "Save As: " .. tostring(v) end
				end
			end
		})
	end

	if not self:IsExcluded("Config Operations") then
		PrestineLib:AddSection({ Tab = "Config", MainTitle = "Config Operations" })
	end

	if not self:IsExcluded("Create / Save Config") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Create / Save Config",
			SubTitle = "Save As: " .. tostring(configNameInput),
			Callback = function()
				local name = (configNameInput and configNameInput ~= "") and configNameInput or "Default"
				if saveToScope(name) then
					refreshDropdown()
					pcall(function() PrestineLib:AddNotification({ TitleText = "Config", ContentText = "[" .. configScope .. "] Saved: " .. name, Duration = 3 }) end)
				else
					pcall(function() PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Save failed", Duration = 3 }) end)
				end
			end
		})
		saveBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Overwrite Selected Config") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Overwrite Selected Config",
			SubTitle = "Target: " .. tostring(selectedConfig),
			Callback = function()
				if selectedConfig and selectedConfig ~= "" then
					if saveToScope(selectedConfig) then
						pcall(function() PrestineLib:AddNotification({ TitleText = "Config", ContentText = "[" .. configScope .. "] Overwrote: " .. selectedConfig, Duration = 3 }) end)
					end
				end
			end
		})
		overwriteBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Load Selected Config") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Load Selected Config",
			SubTitle = "Target: " .. tostring(selectedConfig),
			Callback = function()
				if selectedConfig and selectedConfig ~= "" then
					if loadFromScope(selectedConfig) then
						pcall(function() PrestineLib:AddNotification({ TitleText = "Config", ContentText = "[" .. configScope .. "] Loaded: " .. selectedConfig, Duration = 3 }) end)
					else
						pcall(function() PrestineLib:AddNotification({ TitleText = "Config", ContentText = "File not found in " .. configScope .. " scope", Duration = 3 }) end)
					end
				end
			end
		})
		loadBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Delete Selected Config") then
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Delete Selected Config",
			SubTitle = "Target: " .. tostring(selectedConfig),
			Callback = function()
				if selectedConfig and selectedConfig ~= "" then
					deleteFromScope(selectedConfig)
					local deleted = selectedConfig
					selectedConfig = "Default"
					updateAllTargetLabels()
					refreshDropdown()
					pcall(function() PrestineLib:AddNotification({ TitleText = "Config", ContentText = "[" .. configScope .. "] Deleted: " .. deleted, Duration = 3 }) end)
				end
			end
		})
		delBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Config Automation") then
		PrestineLib:AddSection({ Tab = "Config", MainTitle = "Config Automation" })
	end

	if not self:IsExcluded("Set As Autoload") then
		local autoloadFile = localPath .. "/_autoload.txt"
		local btn = PrestineLib:AddButton({
			Tab = "Config",
			MainName = "Set As Autoload",
			SubTitle = "Target: " .. tostring(selectedConfig),
			Callback = function()
				if selectedConfig and selectedConfig ~= "" then
					pcall(function()
						writefile(autoloadFile, configScope .. "|" .. selectedConfig)
					end)
					pcall(function() PrestineLib:AddNotification({ TitleText = "Config", ContentText = "Autoload → [" .. configScope .. "] " .. selectedConfig, Duration = 3 }) end)
				end
			end
		})
		autoBtnSub = getSubtitleLabel(btn)
	end

	if not self:IsExcluded("Auto Save Component Toggles") then
		PrestineLib:AddSaveToggle({
			Tab = "Config",
			MainName = "Auto Save Component Toggles",
			DefaultState = true
		})
	end

	task.spawn(function()
		task.wait(1.5)
		pcall(function()
			local autoloadFile = localPath .. "/_autoload.txt"
			if isfile(autoloadFile) then
				local raw = readfile(autoloadFile)
				if raw and raw ~= "" then
					local scope, name = raw:match("^([^|]+)|(.+)$")
					if not scope then
						scope = "Local"
						name = raw
					end
					local savedScope = configScope
					configScope = scope
					if loadFromScope(name) then
						if _G.PrestineManagerConfig then
							for k, v in pairs(_G.PrestineManagerConfig) do
								self.Config[k] = v
							end
						end
					end
					configScope = savedScope
				end
			end
		end)
	end)
end

-- Starts the Home-tab background loops: character status, server info, perf
-- text, and fps tracking. Safe to call more than once -- only runs once ever.
-- Called automatically at the end of SetupHome, so you don't need to call this
-- yourself in normal use (whether Home was set up via Init or via SetupTab).
function PrestineManager:StartMonitors()
	if self._monitorsStarted then return end
	self._monitorsStarted = true

	if self._uiConn then self._uiConn:Disconnect() end
	self._uiConn = RunService.Heartbeat:Connect(function()
		local char = player.Character
		if not char then return end

		local hum = char:FindFirstChildOfClass("Humanoid")
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hum then return end

		local statusText =
			"Task: " .. tostring(self.State.CurrentTask) ..
			"\nQueue: " .. #self._queue ..
			"\nMethod: " .. self.Config.TravelMethod ..
			"\nTweenSpeed: " .. self.Config.TweenSpeed ..
			"\nTeleportDelay: " .. self.Config.TeleportDelay ..
			"\nWalkSpeed: " .. hum.WalkSpeed ..
			"\nJump: " .. (hum.UseJumpPower and hum.JumpPower or hum.JumpHeight) ..
			"\nHealth: " .. string.format("%.0f/%.0f", hum.Health, hum.MaxHealth)

		if hrp then
			statusText ..= "\nState: " .. hum:GetState().Name .. "\nRoot Anchored: " .. tostring(hrp.Anchored)
		end

		if self._statusParagraph then
			self._statusParagraph:SetContent(statusText)
		end
	end)

	task.spawn(function()
		while true do
			task.wait(1)
			if self._serverStatusParagraph then
				self._serverStatusParagraph:SetContent(getServerInfoText())
			end
		end
	end)

	task.spawn(function()
		while true do
			task.wait(0.5)
			if self._perfParagraph then
				self._perfParagraph:SetContent(getPerformanceText(self))
			end
		end
	end)

	if self._fpsConn then self._fpsConn:Disconnect() end
	self._fpsConn = RunService.RenderStepped:Connect(function(dt)
		PrestineManager._fps = math.floor(1 / math.max(dt, 0.001))
	end)
end

function PrestineManager:Init(PrestineLib, options)
	self._initOptions = options or {}

	if not getgenv()._PrestineMain and self._initOptions.GUIArgs then
		local success = PrestineLib:CreateGUI(self._initOptions.GUIArgs)
		if success == false then return end
	end

	-- Which tabs get built. Defaults to everything in TabRegistry; pass
	-- options.Tabs = {"Home", "Player"} to Init to only include those.
	local defaultTabNames = {}
	for _, entry in ipairs(self.TabRegistry) do
		table.insert(defaultTabNames, entry.Name)
	end
	local tabsToInit = self._initOptions.Tabs or defaultTabNames

	local tabsToCreate = {}
	for _, tabName in ipairs(tabsToInit) do
		if not hasTab(tabName) then
			local entry = self:GetTabEntry(tabName)
			table.insert(tabsToCreate, {
				Name = tabName,
				Icon = entry and entry.Icon or "Info"
			})
		end
	end
	if #tabsToCreate > 0 then
		PrestineLib:CreateTab(tabsToCreate)
	end

	for _, tabName in ipairs(tabsToInit) do
		local entry = self:GetTabEntry(tabName)
		if entry and hasTab(tabName) then
			self[entry.Setup](self, PrestineLib)
		end
	end

	self:StartMonitors()
end

return PrestineManager
