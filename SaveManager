local HttpService = game:GetService("HttpService")
local SaveManager = {}

local savePath = "DefaultGame"
local saveData = {}

function SaveManager:Set(path)
	savePath = path
end

function SaveManager:SetValue(key, value)
	saveData[key] = tostring(value)
end

function SaveManager:Set(key, value)
	saveData[key] = tostring(value)
end

function SaveManager:Get(key, default)
	return saveData[key] ~= nil and saveData[key] or default
end

function SaveManager:Save()
	local fullPath = savePath .. "/SavedConfig.txt"
	local lines = {}
	for key, value in pairs(saveData) do
		table.insert(lines, key .. "=" .. tostring(value))
	end
	local text = table.concat(lines, "\n")
	if writefile then
		if isfolder and not isfolder(savePath) then
			makefolder(savePath)
		end
		writefile(fullPath, text)
	end
end

function SaveManager:Load()
	local fullPath = savePath .. "/SavedConfig.txt"
	if readfile and isfile and isfile(fullPath) then
		local text = readfile(fullPath)
		saveData = {}
		for line in text:gmatch("[^\r\n]+") do
			local key, value = line:match("^(.-)=(.*)$")
			if key and value then
				saveData[key] = value
			end
		end
	end
end

return SaveManager
