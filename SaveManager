local HttpService = game:GetService("HttpService")
local SaveManager = {}

local savePath = "DefaultGame"
local saveData = {}

function SaveManager:Set(path)
	savePath = path
end

function SaveManager:SetValue(key, value)
	saveData[key] = value
end

function SaveManager:Save()
	local fullPath = savePath .. "/SavedConfig.json"
	local json = HttpService:JSONEncode(saveData)
	if writefile then
		if isfolder then
			if not isfolder(savePath) then
				makefolder(savePath)
			end
		end
		writefile(fullPath, json)
	end
end

return SaveManager
